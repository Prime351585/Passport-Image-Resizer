---
import Image from "astro/components/Image.astro"
import logo from "../assets/logo.png"
import logo_mobile from "../assets/logo_mobile.png"

---
<header class="font-link ">
    <div class="navbar fixed top-0 left-0 right-0 flex flex-col items-center px-4 bg-white z-50 shadow-md rounded-b-3xl overflow-hidden transition-all duration-300 ease-in-out md:relative md:shadow-none md:rounded-none md:h-auto" style="height: 5rem;">
        <!-- Top bar with logo and toggle -->
        <div class="w-full flex justify-between items-center h-20 shrink-0">
            <!-- <Image src={logo_mobile} alt={"Logo"} width={60}/> -->
             <a href="/">
                <Image src={logo} alt={"Logo"} width={120}/>
            </a>
            <!-- <div id="logo" class="text-black font-bold text-xl relative z-10">Logo</div> -->
            
            <!-- Desktop Menu -->
            <nav class="hidden md:flex fixed left-1/2 -translate-x-1/2 space-x-7 backdrop-blur-sm p-3 px-5 bg-white/20 rounded-3xl text-black font-bold">
                <a href="/" class="hover:text-primary transition-colors duration-300 ease-in-out">Home</a>
                <div class="relative group">
                    <button class="hover:text-primary transition-colors duration-300 ease-in-out flex items-center space-x-1">
                        <span>Tools</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                    <!-- Dropdown Menu -->
                    <div class="absolute left-0 mt-2 w-48 bg-white rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 overflow-hidden border border-gray-100">
                        <a href="/resize" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Resize Image</a>
                        <a href="/crop" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Crop Image</a>
                        <a href="/compress" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors border-b border-gray-100">Compress Image</a>
                        <a href="/compress-pdf" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Compress PDF</a>
                        <a href="/merge-pdf" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Merge PDF</a>
                    </div>
                </div>
                
                <div class="relative group">
                    <button class="hover:text-primary transition-colors duration-300 ease-in-out flex items-center space-x-1">
                        <span>Convert</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                    <!-- Dropdown Menu -->
                    <div class="absolute left-0 mt-2 w-48 bg-white rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 overflow-hidden border border-gray-100">
                        <a href="/jpeg-to-webp" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors font-medium">JPEG to WebP</a>
                        <a href="/jpeg-to-png" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">JPEG to PNG</a>
                        <a href="/png-to-webp" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">PNG to WebP</a>
                        <a href="/webp-to-jpeg" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">WebP to JPEG</a>
                        <a href="/webp-to-png" class="block px-4 py-3 text-sm hover:bg-primary/5 hover:text-primary transition-colors">WebP to PNG</a>
                    </div>
                </div>
                
                <a href="/passport" class="hover:text-primary transition-colors duration-300 ease-in-out">Passport</a>
                <a href="/blogs" class="hover:text-primary transition-colors duration-300 ease-in-out">Blogs</a>
            </nav>

            <!-- Mobile Menu Button -->
            <button 
                id="menuToggle" 
                class="md:hidden text-black font-bold text-2xl z-10 w-10 h-10 flex items-center justify-center transition-transform duration-300 hover:scale-110"
                aria-label="Toggle menu"
                aria-expanded="false"
            >
                ☰
            </button>
            
            <button class="hidden md:block bg-primary hover:bg-primary/90 p-2 px-4 rounded-3xl text-white transition-colors duration-300 cursor-pointer">
                <a href="/resize">
                    Get Started
                </a>
            </button>
        </div>

        <!-- Mobile Menu (Inside navbar) -->
        <nav id="mobileMenu" class="hidden md:hidden flex-col justify-start items-start w-full px-4 pb-20 pt-4 flex-1 text-black font-bold opacity-0 transition-opacity duration-300 overflow-y-auto">
            <a href="/" class="menu-item w-full py-4 hover:text-primary transition-colors duration-300 border-b border-gray-100">Home</a>
            
            <p class="w-full py-2 mt-2 text-gray-400 text-xs uppercase tracking-wider">Image Tools</p>
            <a href="/resize" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">Resize Image</a>
            <a href="/crop" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">Crop Image</a>
            <a href="/compress" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">Compress Image</a>
            
            <p class="w-full py-2 mt-4 text-gray-400 text-xs uppercase tracking-wider">PDF Tools</p>
            <a href="/compress-pdf" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">Compress PDF</a>
            <a href="/merge-pdf" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">Merge PDF</a>
            
            <p class="w-full py-2 mt-4 text-gray-400 text-xs uppercase tracking-wider">Convert</p>
            <a href="/jpeg-to-webp" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">JPEG to WebP</a>
            <a href="/jpeg-to-png" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">JPEG to PNG</a>
            <a href="/png-to-webp" class="menu-item w-full py-3 hover:text-primary transition-colors duration-300 border-b border-gray-100 pl-4">PNG to WebP</a>
            
            <a href="/passport" class="menu-item w-full py-4 mt-4 hover:text-primary transition-colors duration-300 border-b border-gray-100">Passport</a>
            <a href="/blogs" class="menu-item w-full py-4 hover:text-primary transition-colors duration-300 border-b border-gray-100">Blogs</a>
            
            <button class="bg-primary hover:bg-primary/90 p-3 px-6 rounded-3xl text-white text-center mt-6 w-full transition-colors duration-300">
                Get Started
            </button>
        </nav>
    </div>
</header>

<script>
    const menuToggle = document.getElementById('menuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    const navbar = document.querySelector('.navbar') as HTMLElement;
    
    if (menuToggle && mobileMenu && navbar) {
        let isOpen = false;
        
        menuToggle.addEventListener('click', () => {
            isOpen = !isOpen;
            
            if (isOpen) {
                // Open menu
                mobileMenu.classList.remove('hidden');
                mobileMenu.classList.add('flex');
                
                navbar.style.height = '100vh';
                navbar.style.borderRadius = '0';
                
                // Fade in menu after height animation starts
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => {
                        mobileMenu.style.opacity = '1';
                    });
                });
                
                menuToggle.textContent = '✕';
                menuToggle.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden'; // Prevent body scroll
            } else {
                // Close menu
                mobileMenu.style.opacity = '0';
                navbar.style.height = '5rem';
                navbar.style.borderRadius = '0 0 1.5rem 1.5rem';
                
                // Wait for animations to complete
                setTimeout(() => {
                    mobileMenu.classList.add('hidden');
                    mobileMenu.classList.remove('flex');
                }, 300);
                
                menuToggle.textContent = '☰';
                menuToggle.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = ''; // Restore body scroll
            }
        });
        
        // Close menu when clicking on menu items
        const menuItems = mobileMenu.querySelectorAll('.menu-item');
        menuItems.forEach(item => {
            item.addEventListener('click', () => {
                if (isOpen) {
                    menuToggle.click(); // Trigger the toggle to close
                }
            });
        });
    }
</script>

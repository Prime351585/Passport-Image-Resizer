---
import Layout from '../layouts/Layout.astro';
import ConvertToolContainer from '../components/ConvertToolContainer';
---

<Layout 
  title="Image Format Converter - Convert Between Formats"
  description="Convert images between JPEG, PNG, and WebP formats with customizable quality settings. Fast, secure, and browser-based conversion."
>
  <!-- Hero Section -->
  <div class="bg-white text-center font-crimson mt-[80px] md:mt-10">
    <h1 class="text-[50px] md:text-[100px] leading-tight">  
      Convert Images<br/>
      <span class="text-primary">Effortlessly</span>
    </h1>
    <p class="text-gray-500 text-lg md:text-xl mt-4 max-w-2xl mx-auto px-4">
      Transform between JPEG, PNG, and WebP formats instantly. All processing happens in your browser.
    </p>
  </div>
  
  <!-- Tool Container -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-8">
    <ConvertToolContainer client:load />
  </div>


  <!-- Features Section -->
  <div class="mt-12 px-5 max-w-7xl mx-auto">
    <p class="text-primary font-crimson text-lg mb-3">
      Supported Formats
    </p>
    <h2 class="font-crimson text-[30px] md:text-[50px] mb-6">
      Choose Your Format
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="flex flex-col p-6 border-t-2 border-gray-200">
        <div class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl mb-4 flex items-center justify-center">
          <span class="text-white text-2xl">📸</span>
        </div>
        <p class="font-crimson text-lg font-medium mb-2">JPEG</p>
        <p class="text-gray-500 text-sm">Best for photos. Smaller file sizes with adjustable quality for web and sharing.</p>
      </div>

      <div class="flex flex-col p-6 border-t-2 border-gray-200">
        <div class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl mb-4 flex items-center justify-center">
          <span class="text-white text-2xl">🖼️</span>
        </div>
        <p class="font-crimson text-lg font-medium mb-2">PNG</p>
        <p class="text-gray-500 text-sm">Best for graphics with transparency. Lossless compression for crisp logos and illustrations.</p>
      </div>

      <div class="flex flex-col p-6 border-t-2 border-gray-200">
        <div class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl mb-4 flex items-center justify-center">
          <span class="text-white text-2xl">🚀</span>
        </div>
        <p class="font-crimson text-lg font-medium mb-2">WebP</p>
        <p class="text-gray-500 text-sm">Modern format with excellent compression. Smaller than JPEG/PNG with better quality.</p>
      </div>
    </div>
  </div>

  <!-- Benefits Section -->
  <div class="mt-16 px-5 max-w-7xl mx-auto mb-16">
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8 md:p-12">
      <h2 class="font-crimson text-[30px] md:text-[50px] mb-6 text-center">
        Why Convert Image Formats?
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">Web Optimization</p>
            <p class="text-gray-600 text-sm">Convert to WebP for faster loading times and better performance on modern websites.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">Compatibility</p>
            <p class="text-gray-600 text-sm">Convert to JPEG or PNG for maximum compatibility across all devices and platforms.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">Quality Control</p>
            <p class="text-gray-600 text-sm">Adjust quality settings to find the perfect balance between file size and visual quality.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">Instant Conversion</p>
            <p class="text-gray-600 text-sm">Convert images in seconds without uploading to servers - everything happens in your browser.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
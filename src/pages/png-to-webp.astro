---
import ToolPageLayout from '../layouts/ToolPageLayout.astro';
import ConvertToolContainer from '../components/ConvertToolContainer';
import { getToolHreflangAlternates, getToolUrl } from '../utils/i18n';

import toolData from '../i18n/tools/png-to-webp-en.json';

const canonicalUrl = getToolUrl('png-to-webp', 'en');
const hreflangAlternates = getToolHreflangAlternates('png-to-webp');
const breadcrumbs = [
  { name: 'Home', url: 'https://www.resize-it.com' },
  { name: toolData.h1, url: canonicalUrl },
];
---

<ToolPageLayout
  lang="en"
  toolData={toolData}
  canonicalUrl={canonicalUrl}
  hreflangAlternates={hreflangAlternates}
  breadcrumbs={breadcrumbs}
>
  <ConvertToolContainer client:load slot="tool" defaultFormat="webp" />
</ToolPageLayout>

---
import ToolPageLayout from '../layouts/ToolPageLayout.astro';
import CompressToolContainer from '../components/CompressToolContainer';
import { getToolHreflangAlternates, getToolUrl } from '../utils/i18n';

// Load English compress i18n data
import toolData from '../i18n/tools/compress-en.json';

const canonicalUrl = getToolUrl('compress', 'en');
const hreflangAlternates = getToolHreflangAlternates('compress');
const breadcrumbs = [
  { name: 'Home', url: 'https://www.resize-it.com' },
  { name: toolData.h1, url: canonicalUrl },
];
---

<ToolPageLayout
  lang="en"
  toolData={toolData}
  canonicalUrl={canonicalUrl}
  hreflangAlternates={hreflangAlternates}
  breadcrumbs={breadcrumbs}
>
  <CompressToolContainer client:load slot="tool" />
</ToolPageLayout>
---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Terms of Service - Resize-It"
  description="Read the terms and conditions for using Resize-It. Understand your rights and responsibilities when using our services."
>
  <!-- Hero Section -->
  <div class="bg-white text-center font-crimson mt-[80px] md:mt-10">
    <h1 class="text-[40px] md:text-[50px] leading-tight">  
      Terms of
      <span class="text-primary">Service</span>
    </h1>
    <p class="text-gray-500 text-lg md:text-xl mt-4 max-w-2xl mx-auto px-4">
      Please read these terms carefully before using our services.
    </p>
  </div>

  <!-- Last Updated -->
  <div class="mt-12 px-5 max-w-4xl mx-auto">
    <p class="text-gray-500 text-sm">
      Last Updated: November 22, 2025
    </p>
  </div>

  <!-- Terms of Service Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-8 space-y-8">
    
    <!-- Agreement to Terms -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Agreement to Terms</h2>
      <p class="text-gray-700 mb-4">
        By accessing and using Resize-It ("the Service"), you accept and agree to be bound by the terms and conditions of this agreement. If you do not agree to these terms, please do not use our Service.
      </p>
      <div class="bg-white rounded-xl p-6 border-2 border-primary/20">
        <p class="font-crimson text-lg font-medium text-primary mb-2">Important Note:</p>
        <p class="text-gray-700">
          Resize-It is provided as a free service. We reserve the right to modify or discontinue the Service at any time without notice.
        </p>
      </div>
    </div>

    <!-- Use of Service -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Use of Service</h2>
      
      <div class="space-y-6">
        <div>
          <h3 class="font-crimson text-xl font-medium mb-3 text-gray-900">Permitted Use</h3>
          <p class="text-gray-700 mb-3">You may use Resize-It to:</p>
          <ul class="space-y-2 ml-6">
            <li class="text-gray-700">• Resize, compress, and convert your own images</li>
            <li class="text-gray-700">• Create passport photo grids for personal or commercial use</li>
            <li class="text-gray-700">• Process images you have the legal right to modify</li>
            <li class="text-gray-700">• Use the Service for both personal and commercial projects</li>
          </ul>
        </div>

        <div>
          <h3 class="font-crimson text-xl font-medium mb-3 text-gray-900">Prohibited Use</h3>
          <p class="text-gray-700 mb-3">You may NOT use Resize-It to:</p>
          <ul class="space-y-2 ml-6">
            <li class="text-gray-700">• Process images you don't have rights to</li>
            <li class="text-gray-700">• Violate any applicable laws or regulations</li>
            <li class="text-gray-700">• Attempt to reverse engineer or copy the Service</li>
            <li class="text-gray-700">• Abuse or overload our infrastructure</li>
            <li class="text-gray-700">• Use the Service for any illegal or harmful purposes</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Intellectual Property -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Intellectual Property</h2>
      
      <div class="space-y-4">
        <div>
          <h3 class="font-crimson text-xl font-medium mb-3 text-gray-900">Your Content</h3>
          <p class="text-gray-700">
            You retain all rights to the images you process using our Service. We do not claim any ownership over your content. Since all processing happens in your browser, we never have access to your images.
          </p>
        </div>

        <div>
          <h3 class="font-crimson text-xl font-medium mb-3 text-gray-900">Our Content</h3>
          <p class="text-gray-700">
            The Service, including its design, code, features, and documentation, is owned by Resize-It and protected by copyright and other intellectual property laws. You may not copy, modify, or distribute any part of the Service without permission.
          </p>
        </div>
      </div>
    </div>

    <!-- Disclaimer of Warranties -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Disclaimer of Warranties</h2>
      <p class="text-gray-700 mb-4">
        THE SERVICE IS PROVIDED "AS IS" AND "AS AVAILABLE" WITHOUT WARRANTIES OF ANY KIND, EITHER EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO:
      </p>
      <ul class="space-y-3">
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Warranties of merchantability or fitness for a particular purpose</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Accuracy, completeness, or reliability of the Service</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Uninterrupted or error-free operation</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Security or freedom from viruses or harmful components</span>
        </li>
      </ul>
      <p class="text-gray-600 text-sm mt-4">
        While we strive to provide a high-quality service, we cannot guarantee perfect results in all situations. Always verify the output meets your requirements.
      </p>
    </div>

    <!-- Limitation of Liability -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Limitation of Liability</h2>
      <p class="text-gray-700 mb-4">
        TO THE MAXIMUM EXTENT PERMITTED BY LAW, RESIZE-IT SHALL NOT BE LIABLE FOR ANY:
      </p>
      <ul class="space-y-3">
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Indirect, incidental, special, or consequential damages</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Loss of profits, data, or business opportunities</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Damages resulting from use or inability to use the Service</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-primary">•</span>
          <span class="text-gray-700">Issues arising from third-party services or browser compatibility</span>
        </li>
      </ul>
      <p class="text-gray-600 text-sm mt-4">
        Since the Service is free, our total liability is limited to the amount you paid to use the Service (which is zero).
      </p>
    </div>

    <!-- User Responsibilities -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">User Responsibilities</h2>
      <p class="text-gray-700 mb-4">As a user of Resize-It, you are responsible for:</p>
      <ul class="space-y-3">
        <li class="flex items-start space-x-3">
          <span class="text-green-500">✓</span>
          <span class="text-gray-700">Ensuring you have the right to process any images you upload</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-green-500">✓</span>
          <span class="text-gray-700">Verifying that processed images meet your quality requirements</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-green-500">✓</span>
          <span class="text-gray-700">Maintaining backups of your original files</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-green-500">✓</span>
          <span class="text-gray-700">Complying with all applicable laws and regulations</span>
        </li>
        <li class="flex items-start space-x-3">
          <span class="text-green-500">✓</span>
          <span class="text-gray-700">Using a modern, secure browser for optimal results</span>
        </li>
      </ul>
    </div>

    <!-- Privacy -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Privacy</h2>
      <p class="text-gray-700 mb-4">
        Your privacy is important to us. Our Privacy Policy explains how we handle your information:
      </p>
      <div class="bg-white rounded-xl p-6 border-2 border-primary/20">
        <ul class="space-y-2">
          <li class="flex items-start space-x-3">
            <span class="text-green-500">✓</span>
            <span class="text-gray-700">All image processing happens in your browser</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-green-500">✓</span>
            <span class="text-gray-700">Your images never leave your device</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-green-500">✓</span>
            <span class="text-gray-700">We don't store or track your images</span>
          </li>
        </ul>
        <p class="text-gray-600 text-sm mt-4">
          Please read our full <a href="/privacy" class="text-primary hover:text-secondary font-medium">Privacy Policy</a> for more details.
        </p>
      </div>
    </div>

    <!-- Modifications to Service -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Modifications to Service</h2>
      <p class="text-gray-700">
        We reserve the right to modify, suspend, or discontinue the Service (or any part thereof) at any time, with or without notice. We may also update these Terms of Service periodically. Continued use of the Service after changes constitutes acceptance of the new terms.
      </p>
    </div>

    <!-- Governing Law -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Governing Law</h2>
      <p class="text-gray-700">
        These Terms shall be governed by and construed in accordance with applicable laws, without regard to conflict of law principles. Any disputes arising from these Terms or your use of the Service shall be resolved through appropriate legal channels.
      </p>
    </div>

    <!-- Severability -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Severability</h2>
      <p class="text-gray-700">
        If any provision of these Terms is found to be unenforceable or invalid, that provision shall be limited or eliminated to the minimum extent necessary, and the remaining provisions shall remain in full force and effect.
      </p>
    </div>

    <!-- Contact Information -->
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-6 text-gray-900">Contact Us</h2>
      <p class="text-gray-700 mb-4">
        If you have any questions about these Terms of Service, please contact us:
      </p>
      <div class="bg-white rounded-xl p-6 border-2 border-primary/20">
        <p class="text-gray-700">
          Email: <a href="mailto:support@resize-it.com" class="text-primary hover:text-secondary font-medium">support@resize-it.com</a>
        </p>
        <p class="text-gray-700 mt-2">
          Or visit our <a href="/contact" class="text-primary hover:text-secondary font-medium">Contact Page</a>
        </p>
      </div>
    </div>

  </div>

  <!-- Bottom CTA -->
  <div class="mt-16 px-5 max-w-7xl mx-auto mb-16">
    <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 md:p-12 text-center">
      <h2 class="font-crimson text-[30px] md:text-[40px] mb-4">
        Ready to Get Started?
      </h2>
      <p class="text-gray-600 text-lg mb-6">
        By using our service, you agree to these terms.
      </p>
      <a href="/" class="inline-block bg-tertiary hover:bg-primary text-primary hover:text-white px-6 py-3 rounded-3xl font-crimson font-semibold transition-all duration-700 ease-in-out">
        Start Using Resize-It
      </a>
    </div>
  </div>

</Layout>

---
import ToolPageLayout from '../layouts/ToolPageLayout.astro';
import FilterToolContainer from '../components/FilterToolContainer';
import { getToolHreflangAlternates, getToolUrl } from '../utils/i18n';

import toolData from '../i18n/tools/lighten-en.json';

const canonicalUrl = getToolUrl('lighten', 'en');
const hreflangAlternates = getToolHreflangAlternates('lighten');
const breadcrumbs = [
  { name: 'Home', url: 'https://www.resize-it.com' },
  { name: toolData.h1, url: canonicalUrl },
];
---

<ToolPageLayout
  lang="en"
  toolData={toolData}
  canonicalUrl={canonicalUrl}
  hreflangAlternates={hreflangAlternates}
  breadcrumbs={breadcrumbs}
>
  <FilterToolContainer client:load slot="tool" filterType="lighten" />
</ToolPageLayout>

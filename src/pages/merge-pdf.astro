---
import ToolPageLayout from '../layouts/ToolPageLayout.astro';
import PDFMergeToolContainer from '../components/PDFMergeToolContainer';
import { getToolHreflangAlternates, getToolUrl } from '../utils/i18n';

import toolData from '../i18n/tools/merge-pdf-en.json';

const canonicalUrl = getToolUrl('merge-pdf', 'en');
const hreflangAlternates = getToolHreflangAlternates('merge-pdf');
const breadcrumbs = [
  { name: 'Home', url: 'https://www.resize-it.com' },
  { name: toolData.h1, url: canonicalUrl },
];
---

<ToolPageLayout
  lang="en"
  toolData={toolData}
  canonicalUrl={canonicalUrl}
  hreflangAlternates={hreflangAlternates}
  breadcrumbs={breadcrumbs}
>
  <PDFMergeToolContainer client:load slot="tool" />
</ToolPageLayout>

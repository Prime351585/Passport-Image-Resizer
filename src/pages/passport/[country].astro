---
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import PassportToolContainer from '../../components/PassportToolContainer';
import { getPassportHreflangAlternates } from '../../utils/i18n';

export async function getStaticPaths() {
  const allPassportFiles = import.meta.glob('../../i18n/passport/*.json', { eager: true });
  const paths = [];

  for (const [filePath, module] of Object.entries(allPassportFiles)) {
    const filename = filePath.split('/').pop() || '';
    const countrySlug = filename.replace('.json', '');
    const countryData = (module as any).default;

    paths.push({
      params: { country: countrySlug },
      props: { countryData, countrySlug }
    });
  }

  return paths;
}

const { countryData, countrySlug } = Astro.props;
const lang = countryData.inLanguage || 'en';
const canonicalUrl = `https://www.resize-it.com/passport/${countrySlug}`;
const hreflangAlternates = getPassportHreflangAlternates(countrySlug);
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Passport', url: '/passport' },
  { name: countryData.h1, url: canonicalUrl },
];

const countryName = countrySlug.split('-').map((word: string) => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
const initialDimension = {
  name: `${countryName} Passport`,
  width: countryData.raw_dimensions?.width_mm || 51,
  height: countryData.raw_dimensions?.height_mm || 51,
  unit: 'mm' as const,
  description: countryData.subtitle || `${countryName} passport photo`,
  country: countryData.country_code || countryName
};
---

<ToolPageLayout
  lang={lang}
  toolData={countryData}
  canonicalUrl={canonicalUrl}
  hreflangAlternates={hreflangAlternates}
  breadcrumbs={breadcrumbs}
>
  <div slot="tool" class="space-y-6">
    <div class="bg-blue-50 border-l-4 border-blue-600 p-6 rounded-r-lg max-w-3xl mx-auto shadow-sm">
      <h2 class="text-xl font-crimson font-bold text-blue-900 mb-2">
        Exact Required Dimensions
      </h2>
      <p class="text-blue-800 text-lg">
        The official dimensions for a {countryName} passport photo are <strong class="font-bold">{initialDimension.width}mm x {initialDimension.height}mm</strong> 
        ({(initialDimension.width / 25.4).toFixed(2)}" x {(initialDimension.height / 25.4).toFixed(2)}").
      </p>
    </div>
    <PassportToolContainer initialDimension={initialDimension} client:load />

    <!-- Helpful Guides Section for SEO internal linking -->
    <div class="max-w-7xl mx-auto mt-12 bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm mb-12">
      <h3 class="text-2xl font-crimson font-bold text-gray-900 mb-4">
        Helpful Passport Photo Guides
      </h3>
      <p class="text-gray-600 mb-6">
        Make sure your {countryName} passport photo is accepted the first time. Check our official guidelines:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/passport/guides/what-to-wear" class="block p-4 border border-gray-100 bg-gray-50 rounded-xl hover:border-primary hover:bg-white hover:shadow-md transition-all group">
          <h4 class="font-bold text-gray-900 group-hover:text-primary mb-1">What to Wear</h4>
          <p class="text-sm text-gray-500">Colors, uniforms, and glasses rules.</p>
        </a>
        <a href="/passport/guides/makeup-rules" class="block p-4 border border-gray-100 bg-gray-50 rounded-xl hover:border-primary hover:bg-white hover:shadow-md transition-all group">
          <h4 class="font-bold text-gray-900 group-hover:text-primary mb-1">Makeup Rules</h4>
          <p class="text-sm text-gray-500">Can you wear makeup? Find out here.</p>
        </a>
      </div>
    </div>
  </div>
</ToolPageLayout>

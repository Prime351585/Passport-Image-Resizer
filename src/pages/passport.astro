---
import Layout from '../layouts/Layout.astro';
import PassportToolContainer from '../components/PassportToolContainer';
---

<Layout 
  title="Passport Photo Grid Maker - Professional ID Photos"
  description="Create professional passport photos with precise cropping and generate printable PDF grids. Perfect for visa applications, ID cards, and official documents."
>
  <!-- Hero Section -->
  <div class="bg-white text-center font-crimson mt-[80px] md:mt-10">
    <h1 class="text-[50px] md:text-[100px] leading-tight">  
      Create Perfect<br/>
      <span class="text-primary">Passport Photos Grid</span>
    </h1>
    <p class="text-gray-500 text-lg md:text-xl mt-4 max-w-2xl mx-auto px-4">
      Generate professional passport photos with precise cropping and printable PDF grids. All processing happens in your browser.
    </p>
  </div>
  <!-- Tool Container -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-8">
    <PassportToolContainer client:load />
  </div>

  <!-- Features Section -->
  <div class="mt-12 px-5 max-w-7xl mx-auto">
    <p class="text-primary font-crimson text-lg mb-3">
      Features
    </p>
    <h2 class="font-crimson text-[30px] md:text-[50px] mb-6">
      Everything You Need
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="flex flex-col p-6 border-t-2 border-gray-200">
        <div class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl mb-4 flex items-center justify-center">
          <span class="text-white text-2xl">📏</span>
        </div>
        <p class="font-crimson text-lg font-medium mb-2">Country Standards</p>
        <p class="text-gray-500 text-sm">Pre-configured dimensions for US, UK, India, and EU passport photos with precise measurements.</p>
      </div>

      <div class="flex flex-col p-6 border-t-2 border-gray-200">
        <div class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl mb-4 flex items-center justify-center">
          <span class="text-white text-2xl">✂️</span>
        </div>
        <p class="font-crimson text-lg font-medium mb-2">Smart Cropping</p>
        <p class="text-gray-500 text-sm">Interactive cropping tool with real-time preview to ensure perfect head positioning and framing.</p>
      </div>

      <div class="flex flex-col p-6 border-t-2 border-gray-200">
        <div class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl mb-4 flex items-center justify-center">
          <span class="text-white text-2xl">📄</span>
        </div>
        <p class="font-crimson text-lg font-medium mb-2">PDF Grid Generator</p>
        <p class="text-gray-500 text-sm">Automatically arrange multiple photos on A4/Letter paper for cost-effective printing.</p>
      </div>
    </div>
  </div>


  <!-- Benefits Section -->
  <div class="mt-16 px-5 max-w-7xl mx-auto mb-16">
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8 md:p-12">
      <h2 class="font-crimson text-[30px] md:text-[50px] mb-6 text-center">
        Why Use Our Passport Photo Tool?
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">Meets Official Requirements</p>
            <p class="text-gray-600 text-sm">Pre-configured dimensions match official passport photo standards for major countries worldwide.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">Save Money on Printing</p>
            <p class="text-gray-600 text-sm">Generate multiple photos on a single sheet, reducing printing costs significantly.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">100% Private & Secure</p>
            <p class="text-gray-600 text-sm">All image processing happens in your browser. Your photos never leave your device.</p>
          </div>
        </div>

        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl">✓</span>
          </div>
          <div>
            <p class="font-crimson text-lg font-medium mb-2 text-gray-900">Professional Quality</p>
            <p class="text-gray-600 text-sm">High-resolution output at 300 DPI ensures your photos meet professional printing standards.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

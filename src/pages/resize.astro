---
import ToolPageLayout from '../layouts/ToolPageLayout.astro';
import ImageToolContainer from '../components/ImageToolContainer';
import { getToolHreflangAlternates, getToolUrl } from '../utils/i18n';

// Load English resize i18n data
import toolData from '../i18n/tools/resize-en.json';

const canonicalUrl = getToolUrl('resize', 'en');
const hreflangAlternates = getToolHreflangAlternates('resize');
const breadcrumbs = [
  { name: 'Home', url: 'https://www.resize-it.com' },
  { name: toolData.h1, url: canonicalUrl },
];
---

<ToolPageLayout
  lang="en"
  toolData={toolData}
  canonicalUrl={canonicalUrl}
  hreflangAlternates={hreflangAlternates}
  breadcrumbs={breadcrumbs}
>
  <ImageToolContainer client:load slot="tool" />
</ToolPageLayout>
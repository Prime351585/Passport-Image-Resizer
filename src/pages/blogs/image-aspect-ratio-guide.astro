        </button>
      </div>
    </div>

    <!-- Related Articles -->
    <div class="mt-16 mb-16">
      <h2 class="font-crimson text-[30px] md:text-[40px] text-gray-900 mb-8">Related Articles</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/blogs/photo-frame-sizes-guide" class="group">
          <div class="bg-white border-2 border-gray-200 rounded-xl overflow-hidden hover:border-primary transition-all duration-300">
            <div class="h-40 bg-gradient-to-br from-tertiary to-green-50"></div>
            <div class="p-4">

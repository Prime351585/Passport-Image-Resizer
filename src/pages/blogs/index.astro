---
import Image from 'astro/components/Image.astro';
import Layout from '../../layouts/Layout.astro';

// Blog posts data - Add new blog posts here
const blogPosts = [
  {
    title: "Standard Photo Frame Sizes: Complete Guide to All Frame Dimensions 2025",
    slug: "photo-frame-sizes-guide",
    excerpt: "Every standard photo frame size explained — from 4×6\" snapshots to 24×36\" poster frames. Includes a full frame size chart, wall art sizing tips, and pixel dimensions for printing.",
    date: "2026-02-25",
    category: "Guides",
    readTime: "10 min read",
    image: "https://images.unsplash.com/photo-1513475382585-d06e58bcb0e0?w=800&h=400&fit=crop"
  },
  {
    title: "What to Wear for a Passport Photo: Complete Dress Code Guide 2025",
    slug: "passport-photo-dress-code",
    excerpt: "Can you wear glasses, makeup, a tank top, or a turtleneck in your passport photo? Complete dress code guide answering every clothing question — so your photo is accepted first time.",
    date: "2026-02-25",
    category: "Guides",
    readTime: "9 min read",
    image: "https://images.unsplash.com/photo-1521791136064-7986c2920216?w=800&h=400&fit=crop"
  },
  {
    title: "Image Aspect Ratio Guide: Understanding Picture Ratios for Every Platform 2025",
    slug: "image-aspect-ratio-guide",
    excerpt: "What is a 3:2 aspect ratio? Complete guide to all common image ratios — 16:9, 4:3, 1:1, 9:16 — with a platform reference table, print matching chart, and how to change ratios without stretching.",
    date: "2026-02-25",
    category: "Tutorials",
    readTime: "9 min read",
    image: "https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=800&h=400&fit=crop"
  },
  {
    title: "Standard Photo Print Sizes: Complete Guide to Every Print Dimension 2025",
    slug: "standard-photo-print-sizes",
    excerpt: "Full photo print size chart in inches, cm, and pixels at 300 DPI. Covers square photo prints, TikTok profile picture sizes, and how to prepare any photo for sharp results.",
    date: "2026-02-25",
    category: "Guides",
    readTime: "10 min read",
    image: "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?w=800&h=400&fit=crop"
  },
  {
    title: "How to Convert a Screenshot to PDF: Step-by-Step Guide for All Platforms 2025",
    slug: "screenshot-to-pdf-guide",
    excerpt: "Learn how to save a screenshot as a PDF on Windows, Mac, iPhone, and Android — using only built-in tools. No third-party software required for most methods.",
    date: "2026-02-25",
    category: "Tutorials",
    readTime: "8 min read",
    image: "https://images.unsplash.com/photo-1517430816045-df4b7de11d1d?w=800&h=400&fit=crop"
  },
  {
    title: "Twitter Image Size Guide 2025: Perfect Dimensions for Posts, Headers & Profile Photos",
    slug: "twitter-image-size-guide",
    excerpt: "Complete guide to Twitter image sizes. Learn exact dimensions for profile pictures, header images, post photos, and Twitter cards. Optimize your Twitter presence with perfect sizing.",
    date: "2025-12-07", 
    category: "Social Media",
    readTime: "11 min read",
    image: "https://images.unsplash.com/photo-1611605698335-8b1569810432?w=800&h=400&fit=crop"
  },
  {
    title: "3000x3000 Image Guide: Creating Perfect Square Photos for Print & Web 2025",
    slug: "3000x3000-image-guide",
    excerpt: "Complete guide to creating 3000x3000 pixel images for album covers, product photos, and professional prints. Learn optimal formats, file size management, and platform requirements.",
    date: "2025-12-03",
    category: "Tutorials",
    readTime: "10 min read",
    image: "https://images.unsplash.com/photo-1611162616305-c69b3fa7fbe0?w=800&h=400&fit=crop"
  },
  {
    title: "Complete Passport Photo Requirements Guide 2025: Everything You Need to Know",
    slug: "passport-photo-requirements-guide",
    excerpt: "Ultimate guide to passport photo requirements for US, India, and 190+ countries. Learn exact dimensions, background rules, and create compliant photos online for free.",
    date: "2025-12-02",
    category: "Guides",
    readTime: "12 min read",
    image: "https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=800&h=400&fit=crop"
  },
  {
    title: "How to Optimize Images for Web: A Complete Guide",
    slug: "optimize-images-for-web",
    excerpt: "Learn the best practices for optimizing images for faster website loading times without sacrificing quality.",
    date: "2025-11-20",
    category: "Tutorials",
    readTime: "8 min read",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=400&fit=crop"
  }

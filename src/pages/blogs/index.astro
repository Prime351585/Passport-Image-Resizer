const categories = [...new Set(blogPosts.map(post => post.category))];
---

<Layout 
  title="Blog - Image Optimization Tips & Guides | ImageTools"
  description="Learn about image optimization, compression techniques, format conversion, and professional photo editing. Expert guides and tutorials for better web performance."
>
  <!-- Hero Section -->
  <div class="bg-white text-center font-crimson mt-[80px] md:mt-10">
    <h1 class="text-[50px] md:text-[100px] leading-tight">  
      Our<br/>
      <span class="text-primary">Blog</span>
    </h1>
    <p class="text-gray-500 text-lg md:text-xl mt-4 max-w-2xl mx-auto px-4">
      Expert guides, tutorials, and tips for image optimization and processing.
    </p>
  </div>

  <!-- Categories -->
  <div class="mt-12 px-5 max-w-7xl mx-auto">
    <p class="text-primary font-crimson text-lg mb-3">
      Browse by Topic
    </p>
    <div class="flex flex-wrap gap-3 mb-8">
      <button class="px-4 py-2 bg-tertiary text-primary font-crimson font-medium rounded-3xl hover:bg-primary hover:text-white transition-all duration-300">
        All Posts
      </button>
      {categories.map(category => (
        <button class="px-4 py-2 bg-white border-2 border-gray-200 text-gray-700 font-crimson font-medium rounded-3xl hover:border-primary hover:text-primary transition-all duration-300">
          {category}
        </button>
      ))}
    </div>
  </div>

  <!-- Featured Post -->
  <div class="mt-8 px-5 max-w-7xl mx-auto">
    <p class="text-primary font-crimson text-lg mb-3">
      Featured Article
    </p>
    <a href={`/blogs/${blogPosts[0].slug}`} class="block group">
      <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl overflow-hidden hover:border-primary transition-all duration-300">
        <div class="grid md:grid-cols-2 gap-0">
          <div class="relative h-64 md:h-auto overflow-hidden">
            <img 
              src={blogPosts[0].image} 
              alt={blogPosts[0].title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 bg-primary text-white text-sm font-crimson font-medium rounded-full">
                {blogPosts[0].category}
              </span>
            </div>
          </div>
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <div class="flex items-center space-x-4 text-sm text-gray-600 mb-4">
              <span class="font-medium">{new Date(blogPosts[0].date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
              <span>•</span>
              <span>{blogPosts[0].readTime}</span>
            </div>
            <h2 class="font-crimson text-[30px] md:text-[40px] text-gray-900 mb-4 group-hover:text-primary transition-colors">
              {blogPosts[0].title}
            </h2>
            <p class="text-gray-700 text-lg mb-6">
              {blogPosts[0].excerpt}
            </p>
            <div class="flex items-center text-primary font-crimson font-medium group-hover:gap-3 gap-2 transition-all">
              Read Article 
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </a>
  </div>

  <!-- Blog Grid -->
  <div class="mt-12 px-5 max-w-7xl mx-auto mb-16">
    <p class="text-primary font-crimson text-lg mb-3">
      Latest Articles
    </p>
    <h2 class="font-crimson text-[30px] md:text-[50px] mb-8">
      Learn & Grow
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {blogPosts.slice(1).map(post => (
        <a href={`/blogs/${post.slug}`} class="group">
          <article class="bg-white border-2 border-gray-200 rounded-2xl overflow-hidden hover:border-primary transition-all duration-300 hover:shadow-lg h-full flex flex-col">
            <div class="relative h-48 overflow-hidden">
              <Image 
                src={post.image} 
                alt={post.title}
                width={32}
                height={32}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute top-4 left-4">
                <span class="px-3 py-1 bg-primary text-white text-sm font-crimson font-medium rounded-full">
                  {post.category}
                </span>
              </div>
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center space-x-3 text-xs text-gray-600 mb-3">
                <span>{new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span>•</span>
                <span>{post.readTime}</span>
              </div>
              <h3 class="font-crimson text-xl md:text-2xl text-gray-900 mb-3 group-hover:text-primary transition-colors">
                {post.title}
              </h3>
              <p class="text-gray-600 text-sm mb-4 flex-grow">
                {post.excerpt}
              </p>
              <div class="flex items-center text-primary font-crimson font-medium text-sm group-hover:gap-2 gap-1 transition-all">
                Read More 
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>

  <!-- Newsletter Section -->
  <div class="mt-16 px-5 max-w-7xl mx-auto mb-16">
    <div class="bg-gradient-to-br from-tertiary to-green-50 border-2 border-secondary/30 rounded-2xl p-8 md:p-12 text-center">
      <div class="w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-white text-3xl">📧</span>
      </div>
      <h2 class="font-crimson text-[30px] md:text-[50px] mb-4">
        Stay Updated
      </h2>
      <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">
        Get the latest image optimization tips, tutorials, and guides delivered to your inbox.
      </p>
      <form class="max-w-md mx-auto flex flex-col sm:flex-row gap-3">
        <input 
          type="email" 
          placeholder="Enter your email"
          class="flex-1 px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-primary focus:outline-none transition-colors"
          required
        />
        <button 
          type="submit"
          class="px-6 py-3 bg-gradient-to-br from-primary to-secondary hover:from-secondary hover:to-primary text-white rounded-xl font-crimson font-semibold transition-all duration-300 hover:scale-105 shadow-lg whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <p class="text-gray-500 text-sm mt-4">
        No spam, unsubscribe anytime. Read our <a href="/privacy" class="text-primary hover:text-secondary">privacy policy</a>.
      </p>
    </div>
  </div>

  <!-- Topics Section -->
  <!-- <div class="mt-16 px-5 max-w-7xl mx-auto mb-16">
    <h2 class="font-crimson text-[30px] md:text-[40px] mb-8 text-center">
      Popular Topics
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="p-6 border-t-2 border-gray-200 hover:border-primary transition-all duration-300 cursor-pointer">
        <div class="w-10 h-10 bg-gradient-to-br from-primary to-secondary rounded-lg mb-3 flex items-center justify-center">
          <span class="text-white text-xl">🎨</span>
        </div>
        <p class="font-crimson text-lg font-medium">Image Editing</p>
        <p class="text-gray-500 text-sm mt-1">12 articles</p>
      </div>
